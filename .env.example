# Database
# For local development use SQLite (no install needed)
# For production replace with PostgreSQL: postgresql://user:password@host:5432/dbname
DATABASE_URL=sqlite:///./workflow.db

# n8n Integration
# N8N_BASE_URL: the URL where your n8n instance is running
# N8N_API_KEY: found in n8n under Settings > API > Create API Key
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key
